# ---------------------------------------------------------------------------
# Hayy — environment variable reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Supabase — frontend (Vite exposes VITE_ vars to the browser bundle)
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# LiveKit — frontend (Vite exposes this; the wss:// URL is safe to be public)
# ---------------------------------------------------------------------------
VITE_LIVEKIT_URL=

# ---------------------------------------------------------------------------
# Supabase — server-only (Vercel serverless functions; no VITE_ prefix)
# These mirror the VITE_ values above but are set as server-only vars in
# Vercel so they are never baked into the browser bundle.
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# LiveKit — server-only (NEVER expose to browser or prefix with VITE_)
# Find these in your LiveKit Cloud project → Settings → Keys.
# ---------------------------------------------------------------------------
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
